# Deploy AutomatizaWPP - Environment Variables Example
# Copy this to .env and fill in your actual values

# Platform configuration
DEPLOY_PLATFORM=auto                    # Options: auto, vercel, docker, aws
NODE_ENV=production

# Vercel Deployment (if using Vercel)
# Get token: vercel token create
VERCEL_TOKEN=your_vercel_api_token_here

# Google Search Console (choose ONE method)

# Method 1: Path to credentials JSON file
GOOGLE_CREDENTIALS_FILE=./google-creds.json

# Method 2: Inline JSON credentials (alternative to file)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Docker Configuration (if using Docker)
SERVICE_HOST=localhost
SERVICE_PORT=3000

# Database (if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/automatizawpp

# Debug Mode
DEBUG=false                             # Set to true for detailed logs
VERBOSE=false                           # Set to true for verbose output
