BREVO_SENDER_EMAIL="hola@automatizawpp.com"

# IMAP (optional, for inbox view and inbound email debugging)
IMAP_HOST="imappro.zoho.com"
IMAP_PORT="993"
IMAP_USER="hola@automatizawpp.com"
IMAP_PASS=""

# Compliance defaults
MAX_TOUCHES_PER_DAY="2"
QUIET_HOURS_START="20"
QUIET_HOURS_END="8"
DEFAULT_TIMEZONE="America/Sao_Paulo"

# Public Dashboard API
PUBLIC_DASHBOARD_TOKEN=""

# Phase 5A: Webhooks & Event Triggers (Gatillos)
