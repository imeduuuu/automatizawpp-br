EMAIL_PROVIDER="brevo"   # "brevo" | "bird"

# SMTP (optional but recommended for password reset emails)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="587"
SMTP_USER="hola@automatizawpp.com"
SMTP_PASS=""
MAIL_FROM="AutomatizaWPP <hola@automatizawpp.com>"

# Email API fallback (recommended in production when SMTP ports are blocked)
RESEND_API_KEY=""
RESEND_FROM="AutomatizaWPP <hola@automatizawpp.com>"
