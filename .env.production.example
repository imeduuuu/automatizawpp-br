# ═════════════════════════════════════════════════════════════════════
# Sales OS — Environment Variables (PRODUCTION)
# ═════════════════════════════════════════════════════════════════════

# DATABASE
DATABASE_USER=postgres
DATABASE_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DATABASE_NAME=sales_os
DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/sales_os

# REDIS
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_URL=redis://:PASSWORD@redis:6379

# AI — Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_PROVIDER=anthropic

# BIRD API (Multi-channel integration)
BIRD_API_KEY=your_bird_api_key
BIRD_WORKSPACE_ID=your_workspace_id
BIRD_CHANNEL_ID=your_channel_id
BIRD_EMAIL_CHANNEL_ID=your_email_channel_id
BIRD_PHONE_NUMBER=+34xxxxxxxxx

# BREVO (Email API)
BREVO_API_KEY=your_brevo_key
BREVO_SENDER_EMAIL=hola@automatizawpp.com

# SMTP (Zoho Mail)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=hola@automatizawpp.com
SMTP_PASS=your_zoho_password
MAIL_FROM=AutomatizaWPP <hola@automatizawpp.com>

# IMAP (Email retrieval)
IMAP_HOST=imappro.zoho.com
IMAP_PORT=993
IMAP_USER=hola@automatizawpp.com
IMAP_PASS=your_zoho_password

# APP CONFIG
NODE_ENV=production
APP_URL=https://automatizawpp.com
NEXT_PUBLIC_BASE_URL=https://automatizawpp.com
NEXTAUTH_URL=https://automatizawpp.com
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars

# COMPLIANCE
MAX_TOUCHES_PER_DAY=5
QUIET_HOURS_START=21
QUIET_HOURS_END=9
DEFAULT_TIMEZONE=America/Sao_Paulo
WORKSPACE_TIMEZONE=Europe/Madrid

# MONITORING
SENTRY_DSN=https://your_sentry_dsn
LOG_LEVEL=info

# OPTIONAL: Analytics
ANALYTICS_API_KEY=your_analytics_key

# OPTIONAL: Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#sales-os-alerts
